# ─── ZenPose Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Load it with: export $(cat .env | xargs) before running app.py
# Or use python-dotenv: pip install python-dotenv

# ── Gmail SMTP for OTP emails ──────────────────────────────────────────────
# Step 1: Enable 2-Step Verification on your Google account
#         https://myaccount.google.com/security
#
# Step 2: Generate an App Password
#         Google Account → Security → 2-Step Verification → App passwords
#         Choose "Mail" + your device. Copy the 16-character password.
#
# Step 3: Fill in below:
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Without these vars ─────────────────────────────────────────────────────
# OTPs will be printed to the terminal console.
# The app works fully — users just copy the OTP from the server log.
# This is the default development mode.

# ── Example usage ──────────────────────────────────────────────────────────
# Linux/Mac:
#   export EMAIL_USER="your.gmail@gmail.com"
#   export EMAIL_PASS="xxxx xxxx xxxx xxxx"
#   python app.py
#
# Windows PowerShell:
#   $env:EMAIL_USER="your.gmail@gmail.com"
#   $env:EMAIL_PASS="xxxx xxxx xxxx xxxx"
#   python app.py
#
# Windows CMD:
#   set EMAIL_USER=your.gmail@gmail.com
#   set EMAIL_PASS=xxxx xxxx xxxx xxxx
#   python app.py
